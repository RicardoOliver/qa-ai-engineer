# ─── ML Quality Gate — Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

# API endpoint of the deployed ML model
MODEL_API_URL=http://localhost:8000

# Auth token for the model API (Bearer token)
MODEL_API_TOKEN=your_api_token_here

# Slack webhook for QA notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Optional: MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: override Python log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
