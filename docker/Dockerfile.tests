FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# 🔥 IMPORTANTE: atualizar build tools
RUN pip install --upgrade pip setuptools wheel

# Copy project
COPY pyproject.toml ./
COPY src/ ./src/
COPY tests/ ./tests/
COPY config/ ./config/

# Install deps
RUN pip install --no-cache-dir -e ".[dev]"

# Reports
RUN mkdir -p reports/html reports/json reports/coverage reports/logs

ENV PYTHONPATH=/app/src

CMD ["pytest", "tests/", "-v", "--tb=short"]